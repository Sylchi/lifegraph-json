#!/bin/bash
# Pre-push hook - Comprehensive but reasonable checks
# Runs in < 60 seconds typically
#
# Install: git config core.hooksPath .githooks

set -e

echo "Running pre-push checks..."

# 1. Build release (ensures optimizations work)
echo "  Building release..."
if ! cargo build --release --quiet 2>/dev/null; then
    echo "❌ Release build failed"
    exit 1
fi

# 2. Run library tests (fast, core functionality)
echo "  Running library tests..."
if ! cargo test --lib --quiet 2>/dev/null; then
    echo "❌ Library tests failed"
    exit 1
fi

# 3. Run integration tests
echo "  Running integration tests..."
if ! cargo test --tests --quiet 2>/dev/null; then
    echo "❌ Integration tests failed"
    exit 1
fi

echo "✓ Pre-push checks passed"
echo ""
echo "Tip: Run 'cargo test' for full test suite before major pushes"
