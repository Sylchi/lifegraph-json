#!/bin/bash
# Pre-push hook for lifegraph-json
#
# Runs comprehensive checks before allowing a push:
# - All tests
# - Documentation tests
# - Release build check
#
# Install: git config core.hooksPath .githooks

set -e

echo "=== Pre-push Checks ==="
echo ""

# Run all tests
echo "Running all tests..."
if ! cargo test --quiet 2>/dev/null; then
    echo ""
    echo "❌ Tests failed. Run: cargo test"
    exit 1
fi
echo "✓ All Tests OK"

# Run doc tests
echo "Running documentation tests..."
if ! cargo test --doc --quiet 2>/dev/null; then
    echo ""
    echo "❌ Doc tests failed. Run: cargo test --doc"
    exit 1
fi
echo "✓ Doc Tests OK"

# Check release build
echo "Checking release build..."
if ! cargo build --release --quiet 2>/dev/null; then
    echo ""
    echo "❌ Release build failed. Run: cargo build --release"
    exit 1
fi
echo "✓ Release Build OK"

# Check benches compile
echo "Checking benchmarks compile..."
if ! cargo check --benches --quiet 2>/dev/null; then
    echo ""
    echo "❌ Benchmark compilation failed. Run: cargo check --benches"
    exit 1
fi
echo "✓ Benchmarks OK"

echo ""
echo "=== All Pre-push Checks Passed ==="
echo ""
echo "Ready to push! 🚀"
