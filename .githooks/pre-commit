#!/bin/bash
# Pre-commit hook - FAST checks only
# Runs in < 5 seconds typically
#
# Install: git config core.hooksPath .githooks

set -e

echo "Running fast pre-commit checks..."

# 1. Format check (fast)
if ! cargo fmt --check --quiet 2>/dev/null; then
    echo "❌ Format check failed. Run: cargo fmt"
    exit 1
fi

# 2. Quick compile check (catches obvious errors)
if ! cargo check --quiet 2>/dev/null; then
    echo "❌ Compile check failed. Run: cargo check"
    exit 1
fi

echo "✓ Pre-commit checks passed"
