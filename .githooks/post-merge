#!/bin/bash
# Post-merge hook - Quick verification after pull
#
# Install: git config core.hooksPath .githooks

set -e

echo "Running post-merge verification..."

# Check if Cargo.lock changed
if git diff HEAD~1 --name-only 2>/dev/null | grep -q "Cargo.lock"; then
    echo "  Updating dependencies..."
    cargo fetch --quiet 2>/dev/null || true
fi

# Quick compile check
if cargo check --quiet 2>/dev/null; then
    echo "✓ Post-merge verification OK"
else
    echo "⚠️  Compile check failed after merge"
    echo "   Run: cargo check"
fi
